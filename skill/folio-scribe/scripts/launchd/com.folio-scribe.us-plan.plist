<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.folio-scribe.us-plan</string>
    <key>ProgramArguments</key>
    <array>
        <string>__SKILL_DIR__/scripts/run_folio_task.sh</string>
        <string>us_plan</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>__US_PLAN_HOUR__</integer>
        <key>Minute</key>
        <integer>__US_PLAN_MINUTE__</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/launchd-us-plan.out</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/launchd-us-plan.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Library/Frameworks/Python.framework/Versions/3.13/bin</string>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>FOLIO_SCRIBE_AI_CLI</key>
        <string>__AI_CLI__</string>
        <key>FOLIO_SCRIBE_AI_FALLBACK_CLI</key>
        <string>__AI_FALLBACK_CLI__</string>
        <key>FOLIO_SCRIBE_AI_MODEL</key>
        <string>__AI_MODEL__</string>
